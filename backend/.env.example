# ==== MongoDB ====
# Local: mongodb://localhost:27017
# MongoDB Atlas (free tier): mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net
MONGO_URL="mongodb://localhost:27017"
DB_NAME="bravos_camp"

# ==== CORS ====
# Use "*" for development or comma-separated origins in production.
# Example: "https://bravoscamp.com,https://www.bravoscamp.com"
CORS_ORIGINS="*"

# ==== Admin credentials (used for /admin login) ====
ADMIN_EMAIL="admin@admin.com.br"
ADMIN_PASSWORD="123455678"

# ==== JWT signing secret ====
# IMPORTANT: change this to a long random string in production
JWT_SECRET="change-me-to-a-random-long-string"

# ==== Local file storage ====
# Folder (relative or absolute) where uploaded logo/video/images are stored.
# In production, point this to a persistent disk/volume path (e.g. /var/data/uploads).
UPLOAD_DIR="./uploads"

# Maximum upload size in megabytes (safety cap).
MAX_UPLOAD_MB="100"
